# =============================================================================
# NPwned — variables de entorno en la RAÍZ (stack Docker)
# =============================================================================
# Copia este archivo a ".env" en esta misma carpeta:
#   Windows:   copy .env.example .env
#   Linux/mac: cp .env.example .env && chmod 600 .env
#
# Los scripts npm "docker:*" usan: docker compose --env-file .env
#
# MongoDB (URI, base) NO se definen aquí: docker-compose.yml las inyecta al
# servicio "api" (mongodb://mongo:27017). Este .env solo alimenta sustitución
# de variables en el compose y valores que el servicio api hereda del YAML.
# =============================================================================

# --- JWT (obligatorio; cadena larga; cámbiala en producción) ---
JWT_SECRET=npwned-desarrollo-docker-cambiar-en-produccion-min-32-chars-x

# --- Primer administrador (solo si la colección "admins" está vacía al arrancar) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=npwned-admin-inicial-12

# --- Origen del navegador: debe coincidir EXACTAMENTE con la URL (puerto incluido) ---
CORS_ORIGIN=http://localhost:8080

# --- Puerto del HOST publicado hacia el 8080 del contenedor Nginx ---
NPWNED_HTTP_PORT=8080
