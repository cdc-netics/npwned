# =============================================================================
# NPwned API — variables de entorno (desarrollo local con Node)
# =============================================================================
# Copia a ".env" en ESTA carpeta (apps/api):
#   Windows:   copy .env.example .env
#   Linux/mac: cp .env.example .env && chmod 600 .env
#
# Carga: dotenv al arrancar la API (npm run dev -w @npwned/api).
# Con stack Docker completo, Mongo y muchas claves las define el compose;
# este archivo es para cuando corres la API en tu máquina.
# =============================================================================

# --- MongoDB ---
MONGODB_URI=mongodb://127.0.0.1:27017
MONGODB_DB=npwned

# --- JWT (obligatorio en serio; aquí un valor solo para desarrollo local) ---
JWT_SECRET=npwned-desarrollo-local-cambiar-en-produccion-min-32-chars-x

# --- Primer administrador (solo si la colección "admins" está vacía) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=npwned-admin-local-12

# --- Puerto HTTP de Express ---
PORT=3000

# --- Orígenes CORS (coma si hay varios). Angular dev server por defecto: 4200 ---
CORS_ORIGIN=http://localhost:4200

# --- Confía en X-Forwarded-* (1 o true) si la API está detrás de nginx/traefik ---
# TRUST_PROXY=1

# --- (Opcional) Node; "production" en contenedor Docker lo fija la imagen ---
# NODE_ENV=development
